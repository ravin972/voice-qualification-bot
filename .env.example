# =============================================================================
# Voice Qualification Bot — environment template
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# All variables are parsed and validated by app/config/settings.py.
#
# NOTE: values must NOT have trailing `# comment` text on the same line.
# python-dotenv (used for local/uvicorn runs) strips those, but Docker's
# `env_file:` mechanism does not — it would pass the comment through as part
# of the literal value and fail validation. Keep comments on their own line.
# =============================================================================

# --- Application ---
APP_NAME=voice-qualification-bot
# One of: local, staging, production
ENVIRONMENT=local
DEBUG=false
HOST=0.0.0.0
PORT=8000
# Externally reachable URL Twilio uses for webhooks + wss streams
# (e.g. an ngrok/Cloudflare tunnel while developing).
PUBLIC_BASE_URL=http://localhost:8000
# Comma-separated origins allowed to call this API cross-origin — the
# deployed frontend's URL(s) plus local Vite dev ports. Required whenever the
# frontend and backend are on different domains (e.g. Vercel + Render).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://voice-qualification-bot.vercel.app

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_JSON=true

# --- Conversation defaults ---
# Scenarios are loaded from app/scenarios/data/*.yaml — add a file there to add a bot.
# One of: lead_qualifier, loan_qualifier (or any bot id you add)
DEFAULT_SCENARIO_ID=lead_qualifier
MAX_REPROMPTS=2
# Destination number (E.164) for a warm transfer on a qualified/HOT_LEAD outcome.
# Leave unset to skip the transfer attempt.
AGENT_TRANSFER_NUMBER=

# --- Telephony: Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Speech-to-Text: Deepgram ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall
DEEPGRAM_LANGUAGE=en

# --- LLM intent normalisation: OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=3.0

# --- Text-to-Speech: fallback chain ---
# Tried in order: ElevenLabs -> Cartesia -> OpenAI TTS -> local OS voice
# (development only). A billing/auth failure or outage on one tier falls
# through to the next automatically — see app/services/tts_service.py.

# Tier 1 (chosen for voice naturalness)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_TIMEOUT_SECONDS=10.0

# Tier 2. Leave CARTESIA_VOICE_ID unset to skip this tier entirely — voice
# ids are account-specific, there is no universal default to fall back to.
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL=sonic-3
CARTESIA_TIMEOUT_SECONDS=10.0

# Tier 3 (reuses OPENAI_API_KEY above, already required for the LLM classifier)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_TIMEOUT_SECONDS=10.0
